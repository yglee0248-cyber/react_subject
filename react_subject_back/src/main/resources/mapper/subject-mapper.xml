<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="kr.co.iei.subject.model.dao.SubjectDao">

 	<select id="selectSubjectList" resultType="subject">
        select * from subject_tbl
        where 1=1 
        
        <if test="searchKeyword != null and searchKeyword != ''">
            AND UPPER(subject_title) LIKE '%' || UPPER(#{searchKeyword}) || '%'
        </if>
        
        <if test="categoryType != null and categoryType > 0">
            and subject_category = #{categoryType}
        </if>
        
        <if test="levelType != null and levelType > 0">
            and subject_level = #{levelType}
        </if>

        <if test="order == null or order == 0 or order == 1">
            order by subject_no desc
        </if>
        <if test="order == 2">
            order by subject_level asc
        </if>
        <if test="order == 3">
            order by subject_level desc
        </if>
        <if test="order == 4">
            order by subject_count asc
        </if>
        <if test="order == 5">
            order by subject_count desc
        </if>
 	</select>
 	
</mapper>
